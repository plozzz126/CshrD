@model List<R_Team>

@{
    var clients = ViewBag.Clients as List<R_Client> ?? new List<R_Client>();
}

<!-- Team Area Start -->
<section class="team-area pt-90 team-section">
    <div class="container">
        <div class="row">
            <div class="col-md-8 col-md-offset-2">
                <div class="section-title text-center">
                    <h3>our special staff</h3>
                    <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-4">
                    <div class="single-team">
                        <div class="team-image">
                            <img src="@item.PictureUrl" alt="">
                        </div>

                        <div class="team-hover">
                            <h4>@item.FullName</h4>
                            <span class="block">( @item.Position )</span>
                            <p>@item.Desctiption</p>

                            <div class="team-links">
                                <a href="#"><i class="zmdi zmdi-facebook"></i></a>
                                <a href="#"><i class="zmdi zmdi-twitter"></i></a>
                                <a href="#"><i class="zmdi zmdi-pinterest"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<!-- Team Area End -->
<!-- Client Area Start -->
<div class="client-area">
    <div class="container">
        <div class="row">
            <div class="client-carousel">

                @foreach (var item in clients)
                {
                    <div class="single-client">
                        <div class="client-image">
                            <a href="#">
                                <img src="@item.ClientImageUrl" alt="" class="p-img">
                                <img src="@item.ClientImageHoverUrl" alt="" class="s-img">
                            </a>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>
<!-- Client Area End -->
<!-- Newsletter Area Start -->
<section class="newsletter-area bg-light">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-lg-offset-2 col-sm-12 col-xs-12">
                <div class="newsletter-container">
                    <h3>NewsLetter Sign-Up</h3>

                    <div class="newsletter-form">
                        <form action="#" class="mc-form fix">
                            <input type="email" name="email" placeholder="Enter your E-mail">
                            <button type="submit" class="default-btn">subscribe</button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!-- Newsletter Area End -->